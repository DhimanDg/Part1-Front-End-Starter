#:kivy 2.3.1
#:import utils kivy.utils

<PlantDetailScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        Label:
            text: "Plant Detail"
            color: (0, 0, 0, 1)
            font_size: "40sp"
            size_hint: (1, None)
            height: "90dp"
            halign: "left"
            valign: "middle"
            text_size: self.size

        ScrollView:
            do_scroll_x: False

            GridLayout:
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: 8
                padding: (0, 0, 0, 10)

                DetailRow:
                    title: "Profile"
                    subtitle: "View and update your account details"
                    size_hint_y: None
                    height: "300dp"

                DetailRow:
                    title: "Notifications"
                    subtitle: "Reminder and alert preferences"
                    


<DetailRow>:
    size_hint_y: None
    height: "86dp"
    padding: 12
    spacing: 10

    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#EDEDED")
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [18]

    BoxLayout:
        orientation: "vertical"
        spacing: 2

        Label:
            text: root.title
            color: utils.get_color_from_hex("#111111")
            font_size: "22sp"
            bold: True
            halign: "left"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.subtitle
            color: utils.get_color_from_hex("#5A5A5A")
            font_size: "14sp"
            halign: "left"
            valign: "middle"
            text_size: self.size

  